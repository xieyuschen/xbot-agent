# ============================================================================
# xbot 配置
# 复制此文件为 .env 并填写实际值
# ============================================================================

# === 基础配置 ===

LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o
MEMORY_PROVIDER=flat
LOG_LEVEL=info
LOG_FORMAT=json

# === 服务器 ===
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080
# SERVER_READ_TIMEOUT=30
# SERVER_WRITE_TIMEOUT=120

# === LLM 重试 ===
# LLM_RETRY_ATTEMPTS=5
# LLM_RETRY_DELAY=1s
# LLM_RETRY_MAX_DELAY=30s
# LLM_RETRY_TIMEOUT=120s

# === Embedding（letta 模式需要）===
# LLM_EMBEDDING_PROVIDER=openai
# LLM_EMBEDDING_BASE_URL=https://api.openai.com/v1
# LLM_EMBEDDING_API_KEY=sk-xxx
# LLM_EMBEDDING_MODEL=text-embedding-3-small
# LLM_EMBEDDING_MAX_TOKENS=2048

# === Agent ===
AGENT_MAX_ITERATIONS=2000
AGENT_MAX_CONCURRENCY=3
# WORK_DIR=.
# PROMPT_FILE=prompt.md
# SINGLE_USER=false (removed — no longer supported)

# === 上下文管理 ===
# AGENT_CONTEXT_MODE=
# AGENT_ENABLE_AUTO_COMPRESS=true
# AGENT_MAX_CONTEXT_TOKENS=200000
# AGENT_COMPRESSION_THRESHOLD=0.7
# AGENT_PURGE_OLD_MESSAGES=false
# MAX_SUBAGENT_DEPTH=6

# === 会话管理 ===
# MCP_INACTIVITY_TIMEOUT=30m
# MCP_CLEANUP_INTERVAL=5m
# SESSION_CACHE_TIMEOUT=24h

# === 沙箱 ===
SANDBOX_MODE=none
# SANDBOX_DOCKER_IMAGE=ubuntu:22.04
# HOST_WORK_DIR=/home/user
# SANDBOX_IDLE_TIMEOUT_MINUTES=30

# === Remote Runner ===
# SANDBOX_REMOTE_MODE=runner
# SANDBOX_WS_PORT=8080
# SANDBOX_AUTH_TOKEN=
# SANDBOX_PUBLIC_URL=

# === 飞书渠道 ===
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ALLOW_FROM=ou_xxxx,ou_yyyy
# FEISHU_DOMAIN=xxx.feishu.cn

# === QQ 渠道 ===
QQ_ENABLED=false
QQ_APP_ID=
QQ_CLIENT_SECRET=
# QQ_ALLOW_FROM=

# === NapCat 渠道 ===
# NAPCAT_ENABLED=false
# NAPCAT_WS_URL=ws://localhost:3001
# NAPCAT_TOKEN=
# NAPCAT_ALLOW_FROM=

# === Web 渠道 ===
# WEB_ENABLED=false
# WEB_HOST=0.0.0.0
# WEB_PORT=8082
# WEB_STATIC_DIR=
# WEB_UPLOAD_DIR=
# WEB_PERSONA_ISOLATION=false
# WEB_INVITE_ONLY=false
# WEB_USER_SERVER_RUNNER=false

# === OAuth ===
OAUTH_ENABLE=false
# OAUTH_HOST=127.0.0.1
OAUTH_PORT=8081
# OAUTH_BASE_URL=https://your-domain.com

# === 安全与权限 ===
# XBOT_ENCRYPTION_KEY=
# ADMIN_CHAT_ID=
# STARTUP_NOTIFY_CHANNEL=feishu
# STARTUP_NOTIFY_CHAT_ID=oc_xxxx

# === 外部服务 ===
# TAVILY_API_KEY=tvly-xxxxx

# === 诊断 ===
# PPROF_ENABLE=false
# PPROF_HOST=localhost
# PPROF_PORT=6060
